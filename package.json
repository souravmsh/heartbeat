{
    "name": "heartbeat",
    "displayName": "Heartbeat",
    "description": "Helps developers manage productivity, health breaks, tasks, and daily activity.",
    "version": "1.2.0",
    "publisher": "souravmsh",
    "repository": {
        "type": "git",
        "url": "https://github.com/souravmsh/heartbeat.git"
    },
    "icon": "assets/icon.png",
    "author": "Shohrab Hossain <sourav.diubd@gmail.com>",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "heartbeat-sidebar",
                    "title": "Heartbeat",
                    "icon": "$(pulse)"
                }
            ]
        },
        "views": {
            "heartbeat-sidebar": [
                {
                    "type": "webview",
                    "id": "heartbeat.sidebarView",
                    "name": "Heartbeat Dashboard",
                    "icon": "$(pulse)"
                }
            ]
        },
        "commands": [
            {
                "command": "heartbeat.refresh",
                "title": "Refresh Heartbeat Dashboard"
            }
        ],
        "configuration": {
            "title": "Heartbeat",
            "properties": {
                "heartbeat.breaks.interval": {
                    "type": "number",
                    "default": 60,
                    "description": "Interval for break reminders in minutes."
                },
                "heartbeat.salah.method": {
                    "type": "string",
                    "default": "MWL",
                    "description": "Calculation method for Salah times."
                },
                "heartbeat.holidays.source": {
                    "type": "string",
                    "default": "",
                    "description": "Absolute path to holidays.json or holidays.csv."
                },
                "heartbeat.calendar.weekends": {
                    "type": "array",
                    "items": {
                        "type": "number"
                    },
                    "default": [
                        5,
                        6
                    ],
                    "description": "Days of the week to treat as weekends (0=Sun, 1=Mon, ..., 6=Sat)."
                },
                "heartbeat.salah.offsets": {
                    "type": "object",
                    "default": {
                        "Fajr": 0,
                        "Dhuhr": 0,
                        "Asr": 0,
                        "Maghrib": 0,
                        "Isha": 0
                    },
                    "description": "Minute offsets for each prayer time."
                },
                "heartbeat.settings.centralFile": {
                    "type": "string",
                    "default": "",
                    "description": "Path to a central JSON file where settings and data are stored/synced."
                },
                "heartbeat.video.source": {
                    "type": "string",
                    "enum": [
                        "youtube",
                        "local"
                    ],
                    "default": "youtube",
                    "description": "Video player source (YouTube or a Local directory)."
                },
                "heartbeat.video.localPath": {
                    "type": "string",
                    "default": "",
                    "description": "Absolute path to the local directory containing video files."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts"
    },
    "devDependencies": {
        "@types/node": "^18.0.0",
        "@types/vscode": "^1.80.0",
        "typescript": "^5.0.0"
    },
    "dependencies": {
        "plyr": "^3.8.4",
        "yt-search": "^2.13.1"
    }
}
